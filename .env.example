# ── Inquiry form integrations ────────────────────────────────────────────────
# All channels are OPTIONAL. If a channel's vars are absent, that channel is
# skipped (the endpoint still returns ok:true for the channels that ran).
# Copy this file to `.env` and fill in what you have.

# 1. ntfy push notifications (https://ntfy.sh or a self-hosted server)
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=your-topic
# Optional HTTP basic auth for a private ntfy server:
# NTFY_USER=
# NTFY_PASS=

# 2. Email via SMTP (nodemailer)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Rich McKellar <richard@mckellar.dev>
# INQUIRY_EMAIL_TO=richard@mckellar.dev

# 3. Generic webhook (JSON POST with the inquiry payload)
# INQUIRY_WEBHOOK_URL=https://hooks.example.com/endpoint
