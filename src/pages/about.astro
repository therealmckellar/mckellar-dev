---
import BaseLayout from '../layouts/BaseLayout.astro';
import Avatar from '../components/Avatar';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is Richard McKellar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Richard McKellar is an entrepreneur, technology advisor, and Merchant Cash Advance (MCA) specialist based in Morristown, New Jersey. He specializes in helping companies adopt AI agent workflows and advising capital partners on starting and scaling direct lending platforms."
      }
    },
    {
      "@type": "Question",
      "name": "What is Richard McKellar's role at My Commercial Funding?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Richard McKellar serves as the Chief Revenue Officer (CRO) of My Commercial Funding, a premium commercial funding and Merchant Cash Advance platform."
      }
    },
    {
      "@type": "Question",
      "name": "What companies has Richard McKellar been affiliated with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Richard McKellar is affiliated with Whetstone Holdings (where he served as VP and Executive Board Member), My Commercial Funding, and Whetstone DBA brands including Everest Funding, Vader Funding, and Granite Mountain Funding."
      }
    }
  ]
};
---

<BaseLayout
  title="About Richard McKellar | mckellar.dev — Background & Credentials"
  description="Biography, professional background, and credentials of Richard McKellar, AI Adoption Consultant and Merchant Cash Advance Advisor."
  canonicalPath="/about"
  faqSchema={faqSchema}
>
  <div class="w-full flex flex-col gap-8 animate-fade-in">
    <!-- Blog Nav Header -->
    <div class="flex items-center justify-between pb-4 border-b border-[var(--color-border)]">
      <a 
        href="/"
        class="flex items-center gap-1.5 text-xs font-semibold text-indigo-400 hover:text-indigo-300 no-underline cursor-pointer transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Home
      </a>

      <span class="font-mono text-xs text-on-surface-subtle uppercase tracking-wider">
        Biography
      </span>
    </div>

    <!-- Main About Content -->
    <div class="flex flex-col gap-8 max-w-3xl mx-auto w-full py-4">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="flex-shrink-0">
          <Avatar />
        </div>
        <div class="flex-1 flex flex-col gap-3 text-center md:text-left">
          <h1 class="font-display font-extrabold text-[32px] sm:text-[40px] leading-tight text-on-surface text-glow-primary">
            Richard McKellar
          </h1>
          <p class="text-sm sm:text-base text-indigo-400 font-mono tracking-wider uppercase">
            Technology Consultant & Alternative Finance Advisor
          </p>
          <p class="text-xs text-on-surface-subtle">
            Morristown, New Jersey · available for strategic consulting
          </p>
        </div>
      </div>

      <div class="rule my-2"></div>

      <div class="flex flex-col gap-6 text-sm sm:text-base text-on-surface-muted leading-relaxed">
        <h2 class="font-display font-bold text-lg text-on-surface">Professional Overview</h2>
        
        <p>
          Richard McKellar is a veteran alternative asset finance advisor and technology strategist based in <strong>Morristown, NJ</strong>. With over 15 years of dedicated experience in the Merchant Cash Advance (MCA) and revenue-based financing (RBF) sectors, he has built a reputation for designing scalable operational frameworks and leading high-performing teams.
        </p>

        <p>
          Throughout his career, Richard has been directly involved in scaling commercial funding platforms. He previously served as a <strong>Vice President & Executive Board Member at Whetstone Holdings</strong> (which operated prominent DBA brands such as Everest Funding, Vader Funding, and Granite Mountain Funding). In this role, he was instrumental in risk mitigation modeling, ISO channel strategy, and platform operations, having personally funded over <strong>$100M+</strong> in MCA transactions.
        </p>

        <p>
          Currently, Richard serves as the <strong>Chief Revenue Officer (CRO) of My Commercial Funding</strong>, where he oversees sales pipelines, commission systems, and syndication network operations.
        </p>

        <h2 class="font-display font-bold text-lg text-on-surface mt-4">AI Adoption & Automation Consulting</h2>
        
        <p>
          In response to the rapid evolution of generative intelligence, Richard focuses on bridging the gap between cutting-edge AI technologies and financial operations. He operates a specialized consulting practice helping platforms deploy custom context-aware AI agent workflows, automate lead triage/routing pipelines, and integrate AI with collaboration and enterprise messaging channels.
        </p>
        
        <p>
          His dual-competency in AI technology and alternative finance provides a unique, highly focused perspective on reducing operational overhead while accelerating deal velocity.
        </p>
      </div>

      <div class="rule mt-6"></div>

      <div class="flex flex-col gap-4">
        <h2 class="font-display font-bold text-lg text-on-surface">Credentials & Highlights</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="glass-card rounded-xl p-4 border-[var(--color-border)]">
            <h3 class="text-xs font-mono uppercase tracking-wider text-indigo-400 font-bold mb-1">Executive Leadership</h3>
            <p class="text-xs text-on-surface-muted">VP & Executive Board Member, Whetstone Holdings</p>
          </div>
          <div class="glass-card rounded-xl p-4 border-[var(--color-border)]">
            <h3 class="text-xs font-mono uppercase tracking-wider text-amber-400 font-bold mb-1">Asset Volume</h3>
            <p class="text-xs text-on-surface-muted">$100M+ Personally Funded MCA/RBF transactions</p>
          </div>
          <div class="glass-card rounded-xl p-4 border-[var(--color-border)]">
            <h3 class="text-xs font-mono uppercase tracking-wider text-indigo-400 font-bold mb-1">Current Role</h3>
            <p class="text-xs text-on-surface-muted">CRO, My Commercial Funding</p>
          </div>
          <div class="glass-card rounded-xl p-4 border-[var(--color-border)]">
            <h3 class="text-xs font-mono uppercase tracking-wider text-amber-400 font-bold mb-1">Specialization</h3>
            <p class="text-xs text-on-surface-muted">AI Agent workflow adoption & automated lead triage</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
