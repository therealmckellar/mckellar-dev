---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<BaseLayout
  title="Insights Journal | mckellar.dev — Publications on AI & MCA Operations"
  description="Thought leadership, workflow audits, and operational scaling guides written by Richard McKellar."
  canonicalPath="/blog"
>
  <div class="w-full flex flex-col gap-8 animate-fade-in">
    <!-- Blog Nav Header -->
    <div class="flex items-center justify-between pb-4 border-b border-[var(--color-border)]">
      <a 
        href="/"
        class="flex items-center gap-1.5 text-xs font-semibold text-indigo-400 hover:text-indigo-300 no-underline cursor-pointer transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Home
      </a>

      <span class="font-mono text-xs text-on-surface-subtle uppercase tracking-wider">
        Insights Journal
      </span>
    </div>

    <!-- Blog Directory Listing View -->
    <div class="flex flex-col gap-6">
      <div class="text-center sm:text-left">
        <h1 class="font-display font-extrabold text-[28px] sm:text-[34px] leading-tight text-on-surface">
          Advisory Publications
        </h1>
        <p class="text-sm text-on-surface-muted mt-2 max-w-xl">
          Thought leadership and technical guides exploring machine learning adoption, CRM architecture buildout, and Merchant Cash Advance scaling.
        </p>
      </div>

      <!-- Filter Tabs (Vanilla CSS/JS) -->
      <div class="flex flex-wrap gap-2 justify-center sm:justify-start mt-2" id="filter-tabs">
        <button
          data-filter="all"
          class="tab-btn py-2 px-4 rounded-xl text-xs font-semibold border transition-all duration-200 cursor-pointer bg-indigo-500/10 border-indigo-500 text-indigo-300 shadow-[0_0_15px_rgba(99,102,241,0.1)]"
        >
          All Publications
        </button>
        <button
          data-filter="ai"
          class="tab-btn py-2 px-4 rounded-xl text-xs font-semibold border transition-all duration-200 cursor-pointer bg-black/25 border-white/5 text-on-surface-muted hover:border-white/10 hover:bg-white/5"
        >
          AI Insights
        </button>
        <button
          data-filter="funding"
          class="tab-btn py-2 px-4 rounded-xl text-xs font-semibold border transition-all duration-200 cursor-pointer bg-black/25 border-white/5 text-on-surface-muted hover:border-white/10 hover:bg-white/5"
        >
          Merchant Funding
        </button>
      </div>

      <!-- Grid list of articles -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4" id="posts-grid">
        {sortedPosts.map((post) => (
          <div 
            data-category={post.data.category}
            class="post-card glass-card rounded-2xl p-5 flex flex-col justify-between border-[var(--color-border)] hover:border-indigo-500/20 hover:scale-[1.005] duration-300"
          >
            <div class="flex flex-col gap-3">
              <div class="flex items-center gap-2">
                <span class={`px-2 py-0.5 rounded-full text-[9px] font-mono font-bold uppercase tracking-wider ${
                  post.data.category === 'ai' 
                    ? 'bg-indigo-500/10 text-indigo-300 border border-indigo-500/20' 
                    : 'bg-amber-500/10 text-amber-300 border border-amber-500/20'
                }`}>
                  {post.data.category === 'ai' ? 'AI Insights' : 'Merchant Funding'}
                </span>
                <span class="text-[10px] text-on-surface-subtle font-mono">{post.data.date}</span>
              </div>
              <h3 class="font-display font-bold text-base sm:text-lg text-on-surface leading-snug">
                {post.data.title}
              </h3>
              <p class="text-xs sm:text-sm text-on-surface-muted leading-relaxed">
                {post.data.description}
              </p>
            </div>

            <div class="flex items-center justify-between mt-5 pt-3 border-t border-[var(--color-border)]">
              <span class="text-[10px] font-mono text-on-surface-subtle">{post.data.readTime}</span>
              <a 
                href={`/blog/${post.id}`}
                class="text-xs font-semibold text-indigo-400 hover:text-indigo-300 flex items-center gap-1 cursor-pointer transition-colors no-underline"
              >
                Read Article
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Vanilla JS filtering script -->
  <script is:inline>
    const tabs = document.querySelectorAll('#filter-tabs .tab-btn');
    const cards = document.querySelectorAll('#posts-grid .post-card');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Reset tab styles
        tabs.forEach(t => {
          t.className = 'tab-btn py-2 px-4 rounded-xl text-xs font-semibold border transition-all duration-200 cursor-pointer bg-black/25 border-white/5 text-on-surface-muted hover:border-white/10 hover:bg-white/5';
        });
        
        // Style selected tab
        tab.className = 'tab-btn py-2 px-4 rounded-xl text-xs font-semibold border transition-all duration-200 cursor-pointer bg-indigo-500/10 border-indigo-500 text-indigo-300 shadow-[0_0_15px_rgba(99,102,241,0.1)]';

        const filter = tab.getAttribute('data-filter');

        // Show/hide cards
        cards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-category') === filter) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
