---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  "Loan offer review and term analysis",
  "Negotiation and funding strategy support",
  "Application and document preparation",
  "Offer comparison and decision support",
  "Refinance and restructure review",
  "General funding consultation",
];

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "Offer",
  "name": "Funding Consulting — Independent Borrower-Side Advisory",
  "description": "Independent, borrower-side advisory for business owners evaluating capital offers. Richard reviews terms, benchmarks proposals, and helps structure the right funding decision without broker bias.",
  "url": "https://mckellar.dev/funding-consulting",
  "offeredBy": {
    "@type": "Person",
    "name": "Richard McKellar",
    "url": "https://mckellar.dev"
  }
};
---

<BaseLayout
  title="Funding Consulting | Independent, Borrower-Side Capital Advisory"
  description="Independent, borrower-side advisory for business owners evaluating capital offers. Richard reviews terms, benchmarks proposals, and helps structure the right funding decision without broker bias."
  canonicalPath="/funding-consulting"
  articleSchema={offerSchema}
>

  <div class="w-full flex flex-col gap-10 animate-fade-in">

    <!-- Header / Back -->
    <div class="flex items-center justify-between pb-2 border-b border-[var(--color-border)]">
      <a
        href="/"
        class="flex items-center gap-1.5 text-xs font-semibold text-indigo-400 hover:text-indigo-300 no-underline cursor-pointer transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Home
      </a>
      <span class="font-mono text-xs text-on-surface-subtle uppercase tracking-wider">
        Funding Consulting
      </span>
    </div>

    <!-- Hero -->
    <div class="flex flex-col gap-5 max-w-3xl mx-auto w-full text-center py-4">
      <span class="self-center font-mono text-[11px] uppercase tracking-[0.18em] text-teal-400 border border-teal-400/20 bg-[var(--color-teal-dim)] rounded-full px-3 py-1">
        Borrower-Side Advisory
      </span>
      <h1 class="font-display font-extrabold text-[34px] sm:text-[46px] leading-tight text-on-surface text-glow-primary">
        Funding Consulting
      </h1>
      <p class="text-base sm:text-lg text-on-surface-muted leading-relaxed">
        Independent, borrower-side advisory for business owners evaluating capital offers.
        Richard reviews terms, benchmarks proposals, and helps you structure the right funding
        decision <span class="text-on-surface font-semibold">without broker bias</span>.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 mt-2">
        <a
          href="https://calendly.com/richmckellar"
          target="_blank"
          rel="noopener noreferrer"
          class="glass-button px-5 py-3 text-sm font-semibold text-on-surface hover:text-on-surface no-underline"
        >
          Book a Funding Review
        </a>
        <a
          href="mailto:richard@mckellar.dev?subject=Funding Offer Review"
          class="glass-button px-5 py-3 text-sm font-semibold text-on-surface hover:text-on-surface no-underline"
        >
          Send Your Offer for Review
        </a>
      </div>
    </div>

    <!-- What you get -->
    <div class="flex flex-col gap-6 max-w-4xl mx-auto w-full">
      <h2 class="font-display font-bold text-xl sm:text-2xl text-on-surface">What the review covers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          services.map((s) => (
            <div class="glass-card rounded-xl p-5 border-[var(--color-border)]">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <p class="text-sm text-on-surface-muted">{s}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- How it works -->
    <div class="flex flex-col gap-6 max-w-4xl mx-auto w-full">
      <h2 class="font-display font-bold text-xl sm:text-2xl text-on-surface">How it works</h2>
      <ol class="flex flex-col gap-3">
        <li class="glass-card rounded-xl p-5 flex items-start gap-4 border-[var(--color-border)]">
          <span class="font-mono text-sm font-bold text-teal-400">01</span>
          <div>
            <h3 class="text-sm font-semibold text-on-surface">Share your offer or goal</h3>
            <p class="mt-1 text-sm text-on-surface-muted">Send the capital offer you're weighing, or describe the funding you're chasing.</p>
          </div>
        </li>
        <li class="glass-card rounded-xl p-5 flex items-start gap-4 border-[var(--color-border)]">
          <span class="font-mono text-sm font-bold text-teal-400">02</span>
          <div>
            <h3 class="text-sm font-semibold text-on-surface">Term analysis & benchmarking</h3>
            <p class="mt-1 text-sm text-on-surface-muted">Fees, factor rates, APR, repayment, covenants, and prepayment terms — explained in plain English and benchmarked against the market.</p>
          </div>
        </li>
        <li class="glass-card rounded-xl p-5 flex items-start gap-4 border-[var(--color-border)]">
          <span class="font-mono text-sm font-bold text-teal-400">03</span>
          <div>
            <h3 class="text-sm font-semibold text-on-surface">Structure the right decision</h3>
            <p class="mt-1 text-sm text-on-surface-muted">Side-by-side comparison and a clear recommendation — built around your cash flow, not a commission.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Why independent -->
    <div class="flex flex-col gap-4 max-w-4xl mx-auto w-full">
      <div class="glass-card rounded-2xl p-6 sm:p-8 border-[var(--color-border)]">
        <h2 class="font-display font-bold text-lg text-on-surface">Why borrower-side, not a broker</h2>
        <p class="mt-3 text-sm sm:text-base text-on-surface-muted leading-relaxed">
          Most capital conversations are led by whoever earns the placement fee. This practice is
          different: the analysis is built to serve the borrower. Richard reviews your existing
          offers, benchmarks them against the market, and helps you negotiate better terms — and if
          a financing option isn't right for your business, you'll hear that plainly.
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex flex-col gap-5 max-w-3xl mx-auto w-full py-4">
      <div class="rounded-2xl border border-teal-400/20 bg-[var(--color-teal-dim)] p-8 text-center">
        <h2 class="font-display font-bold text-xl text-on-surface">Have an offer already?</h2>
        <p class="mx-auto mt-2 max-w-xl text-sm text-on-surface-muted">
          Send it over for an independent review — no cost, no obligation, no broker bias.
        </p>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
          <a
            href="https://calendly.com/richmckellar"
            target="_blank"
            rel="noopener noreferrer"
            class="glass-button px-5 py-3 text-sm font-semibold text-on-surface hover:text-on-surface no-underline"
          >
            Book a Funding Review
          </a>
          <a
            href="mailto:richard@mckellar.dev?subject=Funding Consultation"
            class="glass-button px-5 py-3 text-sm font-semibold text-on-surface hover:text-on-surface no-underline"
          >
            General Funding Consultation
          </a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
